# ── Required ────────────────────────────────────────────────────────────────
# OpenAI API key (needs access to the gpt-image-2 model)
OPENAI_API_KEY=sk-...

# Organizer always receives an email copy of every caricature,
# with the guest's name in the subject line.
ORGANIZER_EMAIL=mayank.jain@wiseradvisor.com

# ── SMTP (how all emails are sent) ───────────────────────────────────────────
# Example below is Gmail with an App Password (myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# ── Guest list admin (/admin) ────────────────────────────────────────────────
# Password for the guest list editor at /admin
ADMIN_PASSWORD=pick-something-secret
# Guest list persistence: attach "Upstash for Redis" from the Vercel
# Marketplace (Storage tab) and these get injected automatically. Without
# Redis, the app falls back to the hardcoded list in lib/guests.ts and
# admin edits only last until the server restarts.
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# ── Optional ─────────────────────────────────────────────────────────────────
# Image quality: low | medium | high (default high; lower = faster but worse)
IMAGE_QUALITY=high
# Image model (default gpt-image-2; gpt-image-1 / gpt-image-1.5 also work)
# IMAGE_MODEL=gpt-image-2
